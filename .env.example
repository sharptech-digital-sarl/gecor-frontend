# API Configuration
# URL de base de l'API backend
# Ne pas inclure de duplication de /api/v1 - le code le gÃ¨re automatiquement
VITE_API_URL=http://localhost:8000/api/v1

# Version affichée dans l’en-tête et la barre latérale (défaut 1.0 si absent)
VITE_APP_VERSION=1.0

# Logo : fichier dans public/logo/ (ex. default.svg, organisation.png)
VITE_LOGO_FILE=default.svg
# Initiales si l’image est introuvable (optionnel)
# VITE_LOGO_MONOGRAM=AB

# Environment
# development | production
NODE_ENV=development

# Pour la production, utilisez:
# VITE_API_URL=http://your-production-api-url/api/v1
# NODE_ENV=production
